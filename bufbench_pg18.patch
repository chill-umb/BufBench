 	else if (mode == BUFFER_LOCK_EXCLUSIVE)
-		BufferLockAcquire(buffer, buf_hdr, BUFFER_LOCK_EXCLUSIVE);
-	else if (mode == BUFFER_LOCK_SHARE_EXCLUSIVE)
-		BufferLockAcquire(buffer, buf_hdr, BUFFER_LOCK_SHARE_EXCLUSIVE);
