-static bool
-BufferLockHeldByMe(BufferDesc *buf_hdr)
-{
-	PrivateRefCountEntry *entry =
-		GetPrivateRefCountEntry(BufferDescriptorGetBuffer(buf_hdr), false);
-
-	if (!entry)
-		return false;
